# Kreya Environment Variables

# ============================================================
# SUPABASE (Backend Database)
# ============================================================
# Get these from: https://supabase.com/dashboard/project/kuwkdxahsugsfblgbetk/settings/api
SUPABASE_URL=https://kuwkdxahsugsfblgbetk.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================
# SECURITY: Token Encryption (REQUIRED)
# ============================================================
# Used to encrypt Instagram access tokens at rest (AES-256-GCM)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Min 32 characters, must be unique and random
ENCRYPTION_KEY=

# ============================================================
# SECURITY: Authentication Secrets (REQUIRED)
# ============================================================
# OTP pepper for hashing one-time passwords
# Generate: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
OTP_SECRET=

# Database setup protection key (prevents accidental re-initialization)
# Generate: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
SETUP_KEY=

# ============================================================
# INSTAGRAM OAUTH
# ============================================================
# App ID: https://developers.facebook.com/apps
INSTAGRAM_APP_ID=761297643580425

# App Secret from Meta dashboard (keep private!)
INSTAGRAM_APP_SECRET=

# OAuth redirect URL (must match Meta app settings)
INSTAGRAM_REDIRECT_URI=https://kreya-github.vercel.app/api/auth/instagram/callback

# ============================================================
# WHATSAPP
# ============================================================
# Business Phone Number ID from Meta Cloud API
WHATSAPP_PHONE_NUMBER_ID=

# WhatsApp Business Account Access Token (keep private!)
WHATSAPP_ACCESS_TOKEN=

# User phone number for manual testing/alerts
NEXT_PUBLIC_WHATSAPP_NUMBER=+1234567890

# ============================================================
# APP URLs
# ============================================================
# Frontend app URL
NEXT_PUBLIC_APP_URL=https://kreya-github.vercel.app

# ============================================================
# SCHEDULED JOBS (Cron)
# ============================================================
# Bearer token for cron job authentication (Vercel injects this)
# Generate: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
CRON_SECRET=

# ============================================================
# ADMIN ENDPOINTS
# ============================================================
# Bearer token for admin API routes (/api/admin/*)
# Generate: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ADMIN_SECRET=

# ============================================================
# DATABASE (Alternative to Supabase)
# ============================================================
# PostgreSQL connection string (if not using Supabase)
# Format: postgresql://user:password@host:port/database
# POSTGRES_URL=
# DATABASE_URL=

# ============================================================
# ENVIRONMENT
# ============================================================
NODE_ENV=production
